{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for Verdant main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://**" },
        { "url": "https://**" },
        { "url": "http://localhost:*/**" },
        { "url": "http://127.0.0.1:*/**" },
        { "url": "http://*:*/**" },
        { "url": "https://*:*/**" }
      ]
    },
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "fs:allow-app-write",
    "fs:allow-app-read"
  ]
}
